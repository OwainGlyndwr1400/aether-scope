{
  "name": "aether-scope-v4.0",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 3500",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && cross-env VITE_DEV_SERVER_URL=http://localhost:3500 electron .",
    "electron:build": "vite build && electron-builder",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.aetherprime.aetherscope",
    "productName": "AETHER_SCOPE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "public/favicon.ico"
    }
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "postprocessing": "^6.36.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
